generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  mode              String
  overallScore      Float
  toneScore         Float
  volumeScore       Float
  articulationScore Float
  paceScore         Float
  wordsPerMinute    Int
  transcript        String
  focusArea         String
  feedbackJson      String
}
